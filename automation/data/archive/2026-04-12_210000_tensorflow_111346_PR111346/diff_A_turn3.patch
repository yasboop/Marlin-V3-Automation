+	public static void computePostDominators(MethodNode mth) {
+		List<BlockNode> reverseSorted = sortBlocksReverse(mth);
+		BlockNode[] pdoms = buildPostDoms(reverseSorted);
+		applyPostDoms(reverseSorted, pdoms);
+	}
+
+	private static List<BlockNode> sortBlocksReverse(MethodNode mth) {
+		List<BlockNode> blocks = mth.getBasicBlocks();
+		int blocksCount = blocks.size();
+		// Build a reverse-post-order from exit block using predecessors
+		List<BlockNode> sorted = new ArrayList<>(blocksCount);
+		BlockUtils.reverseDfsVisit(mth, sorted::add);
+		// Some blocks may not be reachable from exit in reverse (e.g., infinite loops).
+		// Add any missing blocks at the end.
+		if (sorted.size() != blocksCount) {
+			BitSet visited = new BitSet(blocksCount);
+			for (BlockNode b : sorted) {
+				visited.set(b.getId());
+			}
+			for (BlockNode b : blocks) {
+				if (!visited.get(b.getId())) {
+					sorted.add(b);
+				}
+			}
+		}
+		return sorted;
+	}
+
+	@NotNull
+	private static BlockNode[] buildPostDoms(List<BlockNode> sorted) {
+		int blocksCount = sorted.size();
+		// Map from block's original ID to index in sorted list
+		int[] idToIndex = new int[blocksCount];
+		for (int i = 0; i < blocksCount; i++) {
+			idToIndex[sorted.get(i).getId()] = i;
+		}
+
+		BlockNode[] pdoms = new BlockNode[blocksCount];
+		pdoms[0] = sorted.get(0); // exit block is its own post-dominator
+		boolean changed = true;
+		while (changed) {
+			changed = false;
+			for (int idx = 1; idx < blocksCount; idx++) {
+				BlockNode b = sorted.get(idx);
+				// For post-dominators, use successors (reverse of predecessors for dominators)
+				List<BlockNode> succs = b.getSuccessors();
+				int pickedSucc = -1;
+				BlockNode newIPDom = null;
+				for (BlockNode succ : succs) {
+					int succIdx = idToIndex[succ.getId()];
+					if (pdoms[succIdx] != null) {
+						newIPDom = succ;
+						pickedSucc = succIdx;
+						break;
+					}
+				}
+				if (newIPDom == null) {
+					// Block has no processed successors yet, skip for now
+					continue;
+				}
+				for (BlockNode succ : succs) {
+					int succIdx = idToIndex[succ.getId()];
+					if (succIdx == pickedSucc) {
+						continue;
+					}
+					if (pdoms[succIdx] != null) {
+						newIPDom = intersectPostDom(sorted, pdoms, idToIndex, succ, newIPDom);
+					}
+				}
+				int blockIdx = idToIndex[b.getId()];
+				if (pdoms[blockIdx] != newIPDom) {
+					pdoms[blockIdx] = newIPDom;
+					changed = true;
+				}
+			}
+		}
+		return pdoms;
+	}
+
+	private static BlockNode intersectPostDom(List<BlockNode> sorted, BlockNode[] pdoms, int[] idToIndex,
+			BlockNode b1, BlockNode b2) {
+		int f1 = idToIndex[b1.getId()];
+		int f2 = idToIndex[b2.getId()];
+		while (f1 != f2) {
+			while (f1 > f2) {
+				f1 = idToIndex[pdoms[f1].getId()];
+			}
+			while (f2 > f1) {
+				f2 = idToIndex[pdoms[f2].getId()];
+			}
+		}
+		return sorted.get(f1);
+	}
+
+	private static void applyPostDoms(List<BlockNode> sorted, BlockNode[] pdoms) {
+		BlockNode exitBlock = sorted.get(0);
+		exitBlock.setPostDoms(EmptyBitSet.EMPTY);
+		exitBlock.setIPostDom(null);
+
+		int blocksCount = sorted.size();
+		// Build id-to-index mapping
+		int[] idToIndex = new int[blocksCount];
+		for (int i = 0; i < blocksCount; i++) {
+			idToIndex[sorted.get(i).getId()] = i;
+		}
+
+		for (int i = 1; i < blocksCount; i++) {
+			BlockNode block = sorted.get(i);
+			BlockNode ipdom = pdoms[i];
+			if (ipdom == null) {
+				block.setPostDoms(EmptyBitSet.EMPTY);
+				block.setIPostDom(null);
+				continue;
+			}
+			block.setIPostDom(ipdom);
+			BitSet pdomBS = collectPostDoms(pdoms, idToIndex, ipdom, blocksCount);
+			pdomBS.clear(block.getId());
+			block.setPostDoms(pdomBS);
+		}
+	}
+
+	private static BitSet collectPostDoms(BlockNode[] pdoms, int[] idToIndex, BlockNode ipdom, int blocksCount) {
+		BitSet pdomBS = new BitSet(blocksCount);
+		BlockNode next = ipdom;
+		while (true) {
+			int origId = next.getId();
+			if (pdomBS.get(origId)) {
+				break;
+			}
+			pdomBS.set(origId);
+			BitSet curPDoms = next.getPostDoms();
+			if (curPDoms != null && curPDoms != EmptyBitSet.EMPTY) {
+				pdomBS.or(curPDoms);
+				break;
+			}
+			int idx = idToIndex[origId];
+			if (pdoms[idx] == null || pdoms[idx] == next) {
+				break;
+			}
+			next = pdoms[idx];
+		}
+		return pdomBS;
+	}
